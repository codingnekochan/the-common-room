<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Common Room — Secret Society of Strangers</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <%- include('components/nav') %>
    <main class="document">
      <div class="board-header">
        <h1 class="title">The Common Room</h1>
        <% if (user) { %>
          <a href="/new" class="compose-link">Leave a Word</a>
        <% } %>
      </div>
      <p class="subtitle" style="margin-bottom: 8px">
        Words left by those who have passed through
      </p>

    <!-- 1. GUEST — logged out -->
      <% if (!user) { %>
     <p class="guest-nudge guest-nudge--stranger">
      Names here are not freely given. Those who know the word see more than you do.
    </p>  <% } %>
 
    <!-- 2. SIGNED IN, not yet a member -->
      <% if (user && (!user.isMember && !user.isAdmin)) { %>
        <p class="guest-nudge">
            Welcome, <%= user.username %>!
            You are known to us, but not yet recognized.
            <a href="/join" class="text-link">Speak the word</a> to reveal what has been sealed from you.
        </p>      
    <% } %>
 
    <!-- 3. MEMBER -->
      <% if (user && user.isMember) { %>
        <span class="status-banner status-banner--member">&#10046; Recognized Member : <%= user.username %></span>
      <% } %>
 
    <!-- 4. ADMIN -->
      <% if (user && user.isAdmin) { %>
        <span class="status-banner status-banner--admin">&#10022; Keeper of Records : <%= user.username %></span>
      <% } %>

      <div class="divider"></div>
      <% if (posts && posts.length > 0) { %>
        <ul class="entry-list">
          <% posts.forEach(post => { %>
            <%- include('components/listItem', {post}) %>
          <% }) %>
        </ul>
      <% }  else { %>
          <div class="empty-state">No words have been left. Be the first to break the silence.</div>
        <% } %>
    </main>
  </body>
</html>
